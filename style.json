{
  "version": 8,
  "name": "Aquarelle",
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "pmtiles://https://gablilli-cartografo.hf.space/italy.pmtiles",
      "attribution": "&copy; <a href='https://openstreetmap.org'>OpenStreetMap</a>"
    }
  },
  "sprite": "https://gablilli-cartografo.hf.space/sprites/sprite",
  "glyphs": "https://gablilli-cartografo.hf.space/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "Background",
      "type": "background",
      "paint": {
        "background-color": "hsl(205, 57%, 80%)",
        "background-opacity": 1
      }
    },
    {
      "id": "Land",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": {
        "fill-color": "hsl(46, 65%, 91%)",
        "fill-pattern": "yellow",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 0, 1, 7, 0.8]
      }
    },
    {
      "id": "Land edge bleed",
      "type": "line",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": {
        "line-color": "hsla(38, 45%, 55%, 0.35)",
        "line-blur": ["interpolate", ["linear"], ["zoom"], 4, 3, 10, 6, 16, 10],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 2, 10, 5, 16, 9]
      }
    },
    {
      "id": "Water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": "hsl(205, 57%, 80%)",
        "fill-pattern": "blue",
        "fill-opacity": 1
      }
    },
    {
      "id": "Water outline",
      "type": "line",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "line-blur": 4,
        "line-color": "hsla(195, 0%, 100%, 0.7)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 6, 18, 16]
      }
    },
    {
      "id": "River",
      "type": "line",
      "source": "protomaps",
      "source-layer": "waterway",
      "minzoom": 3,
      "paint": {
        "line-blur": ["interpolate", ["linear"], ["zoom"], 3, 2, 18, 4],
        "line-color": "hsl(205,56%,73%)",
        "line-pattern": "blue",
        "line-width": ["interpolate", ["exponential", 1], ["zoom"], 3, 2, 12, 4, 18, 9, 22, 12]
      }
    },
    {
      "id": "Wood",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "wood", "forest", "park", "grass", "meadow"],
      "paint": {
        "fill-color": "hsl(91, 40%, 70%)",
        "fill-pattern": "green",
        "fill-opacity": 1
      }
    },
    {
      "id": "Wood edge bleed",
      "type": "line",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "wood", "forest", "park", "grass", "meadow"],
      "paint": {
        "line-color": "hsla(95, 45%, 35%, 0.3)",
        "line-blur": ["interpolate", ["linear"], ["zoom"], 6, 3, 12, 6, 16, 9],
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1.5, 12, 4, 16, 7]
      }
    },
    {
      "id": "Grass",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 8,
      "filter": ["in", "kind", "grass", "meadow", "scrub"],
      "paint": {
        "fill-color": "hsl(89, 40%, 78%)",
        "fill-pattern": "green",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "Residential",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 4,
      "maxzoom": 13,
      "filter": ["in", "kind", "residential", "urban"],
      "paint": {
        "fill-color": "hsl(60, 24%, 81%)",
        "fill-pattern": "red",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.5, 9, 0.4, 13, 0.2]
      }
    },
    {
      "id": "Residential edge bleed",
      "type": "line",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 6,
      "maxzoom": 13,
      "filter": ["in", "kind", "residential", "urban"],
      "paint": {
        "line-color": "hsla(30, 40%, 45%, 0.25)",
        "line-blur": ["interpolate", ["linear"], ["zoom"], 6, 2, 13, 5],
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1, 13, 3]
      }
    },
    {
      "id": "Sand",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 7,
      "filter": ["in", "kind", "sand", "beach"],
      "paint": {
        "fill-color": "hsl(54, 100%, 76%)",
        "fill-opacity": 0.15
      }
    },
    {
      "id": "Building",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "buildings",
      "minzoom": 13,
      "paint": {
        "fill-color": {
          "stops": [[13, "hsl(48,25%,73%)"], [16, "hsl(47,32%,77%)"]]
        },
        "fill-pattern": "red",
        "fill-opacity": 1
      }
    },
    {
      "id": "Paper grain overlay",
      "type": "background",
      "paint": {
        "background-pattern": "grain",
        "background-opacity": 0.28
      }
    },
    {
      "id": "Road network",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 7,
      "paint": {
        "line-color": "hsl(0, 0%, 100%)",
        "line-pattern": [
          "match", ["get", "kind"],
          ["highway", "motorway"], "red",
          "white"
        ],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 7, 0.25, 14, 0.5, 22, 1],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          6, 1,
          10, ["match", ["get", "kind"], ["highway", "motorway"], 5, ["trunk"], 3, 2],
          14, ["match", ["get", "kind"], ["highway", "motorway"], 12, ["trunk"], 6, ["primary"], 10, ["secondary"], 8, ["tertiary"], 6, ["minor"], 4, 2],
          18, ["match", ["get", "kind"], ["highway", "motorway", "trunk", "primary"], 20, ["secondary"], 16, ["tertiary"], 12, 8]
        ]
      }
    },
    {
      "id": "Railway",
      "type": "line",
      "source": "protomaps",
      "source-layer": "transit",
      "minzoom": 10,
      "filter": ["==", "kind", "rail"],
      "paint": {
        "line-blur": 2,
        "line-color": "hsla(0, 0%, 85%, 0.3)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2, 16, 8, 22, 22]
      }
    },
    {
      "id": "Road labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 12,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Satoshi Regular", "Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "symbol-placement": "line",
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#2C3229",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "Place labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Satoshi Regular", "Noto Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          4, ["match", ["get", "kind"], "country", 14, 8],
          8, ["match", ["get", "kind"], "country", 18, "city", 14, 10],
          12, ["match", ["get", "kind"], "city", 16, "town", 13, 11]
        ],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#2C3229",
        "text-halo-color": "rgba(255,255,255,0.85)",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.8, 8, 1]
      }
    }
  ],
  "bearing": 0,
  "pitch": 0,
  "center": [12.4964, 41.9028],
  "zoom": 6
}
